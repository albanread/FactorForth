# Rust
target/
**/*.rs.bk
# Cargo.lock IS committed: this crate produces binaries (newfactor,
# newfactor-ui) and the Rust convention is to commit the lockfile for
# binary-producing crates so builds are reproducible.

# VM build artifacts
vm-build/vm/*.obj
vm-build/factor.dll
vm-build/factor.dll.lib
vm-build/factor.dll.exp
vm-build/*.exe
vm-build/*.pdb

# Image artifacts (large, regenerable via scripts/build-image.sh)
*.image

# Logs and scratch
*.log
*.stdout
*.stderr
test_*.txt
nf_diag*.txt
nf_test_*.txt

# OS-level
Thumbs.db
.DS_Store

# IDE
.vscode/
.idea/
*.swp
